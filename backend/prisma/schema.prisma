generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Estate {
  id         Int      @id @default(autoincrement())
  name       String
  address    String
  latitude   Float
  longitude  Float
  rent_price Int
  fee_info   String
  geo_code   String
  img        String
  url        String
  floor_plan String
  area       Float
  years_old  Int
  floor_num  String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
}

model Prefecture {
  id                  Int                   @id @default(autoincrement())
  name                String
  code                String                @unique
  latitude            Float
  longitude           Float
  zoom                Int
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @updatedAt @db.Timestamptz(6)
  PrefectureTrainLine PrefectureTrainLine[]
  Station             Station[]
}

model PrefectureTrainLine {
  id              Int        @id @default(autoincrement())
  prefecture_code String
  train_line_code String 
  created_at      DateTime   @default(now()) @db.Timestamptz(6)
  updated_at      DateTime   @updatedAt @db.Timestamptz(6)
  Prefecture      Prefecture @relation(fields: [prefecture_code], references: [code])
  TrainLine       TrainLine  @relation(fields: [train_line_code], references: [code])
}

model Station {
  id              Int        @id @default(autoincrement())
  name            String
  code            String        @unique
  latitude        Float
  longitude       Float
  zoom            Int
  prefecture_code String
  line_code       String
  created_at      DateTime   @default(now()) @db.Timestamptz(6)
  updated_at      DateTime   @updatedAt @db.Timestamptz(6)
  TrainLine       TrainLine  @relation(fields: [line_code], references: [code])
  Prefecture      Prefecture @relation(fields: [prefecture_code], references: [code])
}

model TrainLine {
  id                  Int                   @id @default(autoincrement())
  name                String
  code                String                @unique
  latitude            Float
  longitude           Float
  zoom                Int
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @updatedAt @db.Timestamptz(6)
  color               String
  PrefectureTrainLine PrefectureTrainLine[]
  Station             Station[]
}
