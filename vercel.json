{
  "version": 2,
  "buildCommand": "cd backend && npm ci && npm run build",
  "outputDirectory": "backend/dist",
  "functions": {
    "backend/dist/index.js": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/backend/dist/index.js"
    }
  ]
}
